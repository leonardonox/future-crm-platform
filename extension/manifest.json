{
  "manifest_version": 3,
  "name": "Future CRM Assistant Cloud",
  "version": "1.0.0",
  "description": "Mensagens rápidas sincronizadas para GHL.",
  "permissions": ["storage"],
  "host_permissions": ["https://app.gohighlevel.com/*", "https://app.leadconnectorhq.com/*", "http://localhost:8000/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["https://app.gohighlevel.com/*", "https://app.leadconnectorhq.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
